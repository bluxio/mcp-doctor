{
  "name": "mcp-doctor",
  "version": "0.2.0",
  "description": "CLI that audits MCP servers for protocol compliance, schema quality, permissions, and latency",
  "type": "module",
  "bin": {
    "mcp-doctor": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "doctor:fixture": "tsx src/cli.ts --stdio \"tsx ../../examples/fixture-server/server.ts\"",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluxio/mcp-doctor.git"
  },
  "homepage": "https://github.com/bluxio/mcp-doctor#readme",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mcp-doctor/core": "workspace:*",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
