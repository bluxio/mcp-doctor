{
  "name": "mcp-doctor-monorepo",
  "private": true,
  "version": "0.2.0",
  "description": "MCP Doctor monorepo — CLI, web app, and GitHub Action",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @mcp-doctor/web dev",
    "dev:cli": "pnpm --filter mcp-doctor dev",
    "doctor:fixture": "pnpm --filter mcp-doctor doctor:fixture",
    "lint": "pnpm -r run build"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@9.15.0"
}
